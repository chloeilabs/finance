{
  "name": "finance",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:migrate": "better-auth migrate -y --config auth.ts",
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "threads:migrate": "node --env-file-if-exists=.env.local threads-migrate.mjs",
    "markets:migrate": "node --env-file-if-exists=.env.local markets-migrate.mjs",
    "markets:capabilities": "node --env-file-if-exists=.env.local markets-capabilities.mjs",
    "markets:capabilities:write": "node --env-file-if-exists=.env.local markets-capabilities.mjs --write",
    "lint": "eslint src e2e auth.ts threads-migrate.mjs markets-migrate.mjs eslint.config.js next.config.mjs playwright.config.ts playwright.live.config.ts postcss.config.mjs test/run-playwright-live-ai.mjs vitest.config.ts --max-warnings=0",
    "lint:fix": "eslint src e2e auth.ts threads-migrate.mjs markets-migrate.mjs eslint.config.js next.config.mjs playwright.config.ts playwright.live.config.ts postcss.config.mjs test/run-playwright-live-ai.mjs vitest.config.ts --fix --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test --config playwright.live.config.ts",
    "test:e2e:copilot": "node test/run-playwright-live-ai.mjs",
    "test:e2e:install": "playwright install chromium",
    "test:watch": "vitest",
    "typecheck": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.32",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@tanstack/react-query": "^5.96.2",
    "@tavily/core": "^0.7.2",
    "ai": "^6.0.146",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "kysely": "^0.28.15",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.6",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "4.1.2",
    "shiki": "^4.0.2",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "1.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "^16.2.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  }
}
